# Public site URL used for canonical URLs, Open Graph URLs, sitemap, robots,
# Better Auth fallback origin, and production metadata.
NEXT_PUBLIC_SITE_URL=""

# Optional Google Analytics 4 measurement ID override.
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# Postgres connection string used by Drizzle, Better Auth, products, FAQ,
# contact message storage, and admin profile data. Use local Postgres for
# development and replace the same variable with Neon in production.
DATABASE_URL=""

# Better Auth production origin and secret.
# Generate BETTER_AUTH_SECRET with a cryptographically strong 32-byte+ value.
BETTER_AUTH_URL=""
BETTER_AUTH_SECRET=""

# Seed-only values for creating the first admin account.
# Add these only when running npm run db:seed, then remove them from Vercel.
ADMIN_EMAIL=""
ADMIN_INITIAL_PASSWORD=""

# Resend email delivery for password reset, contact form, and product inquiry.
# Use a verified sender domain in production.
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""

# Cloudflare Turnstile keys for contact and product inquiry forms.
# Leave both empty locally to bypass Turnstile. Do not set only one key.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Cloudflare R2 product image uploads.
# R2_PUBLIC_BASE_URL must be a public HTTPS URL for uploaded images.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_BASE_URL=""
